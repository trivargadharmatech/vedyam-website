# ===============================================
# VEDYAM ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in the values
# ===============================================

# 1. DATABASE
# PostgreSQL connection string (Neon, Supabase, Vercel Postgres)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# (Optional fallback) For local SQLite only
# VEDYAM_DB="vedyam.db"

# 2. AI SERVICES
# Groq API key for the Simulator Chatbot
GROQ_API_KEY="gsk_..."

# Google Gemini API key for the Main Website Chatbot
GEMINI_API_KEY="AIzaSy..."

# (Optional) Hugging Face Token for external embedding generation (For Vercel deploy)
HF_TOKEN="hf_..."

# 3. SECURITY
# Secret key used for signing JWT tokens. Keep this secure!
VEDYAM_SECRET="your-super-secret-key-change-in-production"

# JWT token expiration in seconds (default 86400 = 24 hours)
VEDYAM_TOKEN_TTL="86400"

# 4. SERVER (Local Development Only)
# VEDYAM_HOST="127.0.0.1"
# VEDYAM_PORT="8000"
# FRONTEND_URL="http://localhost:5173"
